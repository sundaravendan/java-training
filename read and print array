import java.util.Scanner;

public class array {
    public static void main(String[] args) {
        Scanner ece = new Scanner(System.in);
        int N = ece.nextInt();
        int[] arr = new int[N];
        for(int i = 0; i < N; i++) {
            arr[i] = ece.nextInt();
        }
        for(int i = 0; i < N; i++) {
            System.out.print(arr[i] + " ");
        }
    }
}
