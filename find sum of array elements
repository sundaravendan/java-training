import java.util.Scanner;

public class elements 
{
    public static void main(String[]args)
    {
        Scanner ece = new Scanner(System.in);
        int N = ece.nextInt();
        int sum = 0;
        for(int i = 0; i < N; i++)
        {
            int num = ece.nextInt();
            sum += num;
        }
        System.out.println(sum);
    }
}
