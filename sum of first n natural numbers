import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        int N,i;
        Scanner sc=new Scanner(System.in);
        N=sc.nextInt();
        int sum=0;
        
        for(i=1;i<=N;i++)
        {
            sum=sum+i;
            
        }
        System.out.println(sum);
    }
}
