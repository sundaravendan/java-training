import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        int P,R,T,SI;
        Scanner sc=new Scanner(System.in);
        P=sc.nextInt();
        R=sc.nextInt();
        T=sc.nextInt();
        SI=(P*R*T)/100;
        System.out.println(SI);
    }
}
