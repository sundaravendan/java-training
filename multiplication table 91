import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        int N,M;
        Scanner sc=new Scanner(System.in);
        N=sc.nextInt();
        
        
        for(int i=1;i<=10;i++)
        {   M=i*N;
            System.out.println(i+"*"+N+"="+M);
        }
    }
}
