import java.util.Scanner;

public class largest {
    public static void main(String[] args) {
        Scanner s = new Scanner(System.in);
        int N = s.nextInt();
        int max = s.nextInt();
        for(int i = 1; i < N; i++) {
            int num = s.nextInt();
            if(num > max) {
                max = (num);
            }
        }
        System.out.println(max);
    }
}
