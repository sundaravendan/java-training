import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        int age, marks;
        Scanner sc = new Scanner(System.in);

        age = sc.nextInt();
        marks = sc.nextInt();

        if(age >= 18)
        {
            if(marks >= 40)
            {
                System.out.println("Eligible");
            }
            else
            {
                System.out.println("Not Eligible");
            }
        }
        else
        {
            System.out.println("Not Eligible");
        }
    }
}
